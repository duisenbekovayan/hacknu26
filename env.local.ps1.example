# Скопируйте в `.env.local.ps1` в корне репо (файл в .gitignore) и подставьте ключи.

# Вариант A — Google Gemini
# $env:GEMINI_API_KEY = "AIzaSy..."

# Вариант B — OpenRouter (ключи sk-or-v1-…)
# $env:OPENAI_API_KEY = "sk-or-v1-..."
# $env:OPENAI_BASE_URL = "https://openrouter.ai/api/v1"
# $env:OPENAI_MODEL = "openai/gpt-4o-mini"
